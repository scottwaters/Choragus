<?xml version="1.0" encoding="UTF-8"?>
<!--
  Entitlements applied to Sparkle's Installer.xpc when re-signing for
  distribution. Needs sandbox + the user-selected read-write capability
  so Sparkle's installer can replace the running .app bundle from the
  freshly downloaded DMG. Network access is intentionally OMITTED — the
  Downloader.xpc handles all download work; the Installer only relocates
  bundles already on disk.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
